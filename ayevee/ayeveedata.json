    "reviews":{
        "title_img":{
            "url": "../assets/img/user-reviews.png ",
            "width":"316",
            "height":"50",
            "alt":"user reviews"
        },

        "description":"Check out what our users are saying about AIGE",
        "items":[
                {
                    "name": "Akhil S",
                    "profileimg_Url": "../public/image/profile-pic.png",
                    "profileimg_Width": 88,
                    "profileimg_Height": 89,
                    "profileimg_Alt": "review",
                    "review": "Fantabulous 5 star you guys deserve to be in big screen technical wise top notch editing overall its a new gaming crime thriller short movie all the best for your future projects",
                    "imageUrl": "../public/image/review-star.png",
                    "imageWidth": 228,
                    "imageHeight": 40,
                    "imageAlt": "review"
                },
                {
                    "name": "Godwin",
                    "profileimg_Url": "../public/image/profile-pic.png",
                    "profileimg_Width": 88,
                    "profileimg_Height": 89,
                    "profileimg_Alt": "review",
                    "review": "Awesome stuff! Really happy that the Interactive experience now being adapted in India.\nVery engaging story..... could have gone a bit deeper though in investigating the CEO and the cult angle. But really awesome stuff... hope you guys produce more such content. Cheers!",
                    "imageUrl": "../public/image/review-star.png",
                    "imageWidth": 228,
                    "imageHeight": 40,
                    "imageAlt": "review"
                },
                {
                    "name": "Ranjith",
                    "profileimg_Url": "../public/image/profile-pic.png",
                    "profileimg_Width": 88,
                    "profileimg_Height": 89,
                    "profileimg_Alt": "review",
                    "review": "The entire episode was seamless and the mystery was intriguing since you get to play the detective. I'm simply stunned by the amount of effort that's been put into this and I'm in awe at how well they have played understanding human psychology. I am a person who doesn't get scared that often but the mystery kept me on the edge of the seat. I would love to pay to produce such interactive content and I congratulate the team on this one-of-a-kind initiative. I appreciate the tech team and the actors as well! Thank you",
                    "imageUrl": "../public/image/review-star.png",
                    "imageWidth": 228,
                    "imageHeight": 40,
                    "imageAlt": "review"
                },
                {
                    "name": "Fathimath Shifa",
                    "profileimg_Url": "../public/image/profile-pic.png",
                    "profileimg_Width": 88,
                    "profileimg_Height": 89,
                    "profileimg_Alt": "review",
                    "review": "What an amazing gaming experience!! I am sure this is the best investigation game I played in my lifetime. The visual works and characters are amazing so proud of the workers. I am surely suggesting this to my friends and I am very happy to play this game...",
                    "imageUrl": "../public/image/review-star.png",
                    "imageWidth": 228,
                    "imageHeight": 40,
                    "imageAlt": "review"
                },
                {
                    "name": "Suriya",
                    "profileimg_Url": "../public/image/profile-pic.png",
                    "profileimg_Width": 88,
                    "profileimg_Height": 89,
                    "profileimg_Alt": "review",
                    "review": "Best story plot and nice investigation and gameplay is top-notch. I am requesting you to release another case and long time gameplay like 1hr, nice game keep it on",
                    "imageUrl": "../public/image/review-star.png",
                    "imageWidth": 228,
                    "imageHeight": 40,
                    "imageAlt": "review"
                }
            ]
        
    },
